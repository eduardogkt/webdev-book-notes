<!DOCTYPE html>
<html lang="en">
<%- include("partials/head.ejs", {title: "My bookshelf", style: "main.css"}) %>

<body>
  <%- include("partials/header.ejs") %>

  <main class="container min-vh-100 col-lg-6 col-md-8 col-sm-10">
    <div class="hero">
      <h1>My book<span class="underline">shelf</span>.</h1>
      <h2>Books that I've read...</h2>
      <p>Tiny summary but detailed notes for each. This page will constantly
        update as I read more, so bookmark it if you want to check back in a
        few months. This site was inpired by <a href="https://sive.rs/book" target="_blank">
          Derek Sivers' books site</a>.
      </p>
    </div>

    <div class="options">
      <form method="get" action="/" id="sort">
        <select name="sort-books" id="sort-books" class="sort-books" onchange="this.form.submit()">
          <option value="newest-read" <%= sort === "newest-read" ? "selected" : ""  %>>Sort by newest</option>
          <option value="oldest-read" <%= sort === "oldest-read" ? "selected" : ""  %>>Sort by oldest</option>
          <option value="title" <%= sort === "title" ? "selected" : ""  %>>Sort by title</option>
          <option value="rating-best" <%= sort === "rating-best" ? "selected" : ""  %>>Sort by best rating</option>
          <option value="rating-worst" <%= sort === "rating-worst" ? "selected" : ""  %>>Sort by worst rating</option>
        </select>
      </form>

      <a class="btn" href="/add">
        <i class="bi bi-plus-lg"></i>Add book
      </a>
    </div>

    <div class="content">
      <% books.forEach((book) => { %>

      <div class="book" id="book-<%= book.id %>">
        <div class="book-img">
          <img src="https://placehold.co/160x240" alt="">
        </div>
        <div class="book-info">
          <a class="book-title" href="/books/<%= book.id %>" id="title-<%= book.id %>">
            <h3><%= book.title %></h3>
          </a>
          <div class="book-data">
            <p>Read in: <%= book.readIn %></p>
            <div class="book-rating">
              <% for (let i = 0; i < 5; i++) { %>
              <% if (i < book.rating) { %>
              <i class="bi bi-star-fill star filled"></i>
              <% } else { %>
              <i class="bi bi-star-fill star"></i>
              <% } %>
              <% } %>
            </div>
          </div>
          <p class="book-review"><%= book.review %>
          </p>
        </div>
      </div>

      <hr />

      <% }) %>

