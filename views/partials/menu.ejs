<div class="d-flex w-fit position-relative">
  <button class="btn btn-opt" id="opt-btn<%= id %>">
    <i class="bi bi-three-dots-vertical"></i>
  </button>
  <div class="position-absolute top-100 end-0 hide opt-menu" id="opt-menu<%= id %>">
    <a href="/books/<%= id %>/edit">
      <i class="bi bi-pencil"></i>
      Edit
    </a>
    <a href="" data-bs-toggle="modal" data-bs-target="#delete-modal<%= id %>">
      <i class="bi bi-trash3"></i>
      Delete
    </a>
  </div>
</div>