<div class="modal fade" id="delete-modal<%= book.id %>" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Confirmation</h1>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to delete '<%= book.title %>'?</p>
      </div>
      <div class="modal-footer">
        <form>
          <% if (page === "main") { %>
          <a class="btn btn-cancel" data-bs-dismiss="modal" href="/">Cancel</a>
          <% } else { %>
          <a class="btn btn-cancel" data-bs-dismiss="modal" href="/books/<%= book.id %>">Cancel</a>
          <% } %>
          <button class=" btn btn-delete" type="submit" value="submit" formaction="/books/<%= book.id %>/delete" formmethod="post">Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>