<!DOCTYPE html>
<html lang="en">
<%- include("partials/head.ejs", {title: "My bookshelf", style: "book.css"}) %>

<body>
  <%- include("partials/header.ejs") %>

  <main class="container min-vh-100 col-lg-6 col-md-8 col-sm-10">
    <div class="this-book">
      <div class="book-img">
        <img src="<%= book.coverUrl %>" alt="">
      </div>
      <div class="this-book-info">
        <div class="d-flex justify-content-between w-100">
          <div>
            <h1><%= book.title %></h1>
            <h2><%= book.author %></h2>
          </div>
          <%- include("partials/menu.ejs", {id: book.id}) %>
        </div>
        <div class="book-rating">
          <% for (let i = 0; i < 5; i++) { %>
          <% if (i < book.rating) { %>
          <i class="bi bi-star-fill star filled"></i>
          <% } else { %>
          <i class="bi bi-star-fill star"></i>
          <% } %>
          <% } %>
        </div>
        <div class="this-book-data">
          <p>ISBN: <%= book.isbn %></p>
          <p>Read in: <%= book.readIn %></p>
        </div>
      </div>
    </div>
    <div class="this-book-synopsis">
      <p><%= book.synopsis %></p>
    </div>

    <div class="content">
      <h2 class="section-title">My review</h2>
      <% if (book.review) { %>
      <p><%= book.review %></p>
      <% } else { %>
      <p>No review.</p>
      <% } %>
      <br />
      <h2 class="section-title">My notes</h2>
      <% if (book.notes) { %>
      <p><%= book.notes %></p>
      <% } else { %>
      <p>No notes.</p>
      <% } %>
    </div>
  </main>

  <%- include("partials/delete_modal.ejs", {id: book.id}) %>

  <%- include("partials/footer.ejs") %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  <script src="/js/main.js"></script>
</body>

</html>